                    },
                    600: {
                        items: 1,
                    },
                    1000: {
                        items: 1,
                    },
                },
            });
            $(".gym-activity").owlCarousel({
                loop: true,
                margin: 15,
                nav: false,
                dots: true,
                autoplay: true,
                autoplayTimeout: 5000,
                autoplayHoverPause: true,
                responsive: {
                    0: {
                        items: 2,
                    },
                    600: {
                        items: 3,
                    },
                    1000: {
                        items: 3,
                    },
                },
            });
        });
    </script>
    <script type="text/javascript">
        (function($) {
            "use strict";
            $(".courses-slider").owlCarousel({
                loop: true,
                margin: 15,
                autoplay: true,
                nav: false,
                dots: true,
                responsive: {
                    0: {
                        items: 1,
                    },
                    600: {
                        items: 3,
                    },
                    1000: {
                        items: 4,
                    },
                },
            });
        })(jQuery);

        function displayWord() {
            var words = document.getElementsByClassName("changetext");
            var wordCounter = 0;

            setInterval(updateWord, 3500);

            function updateWord() {
                if (wordCounter >= words.length) wordCounter = 0;
                for (var i = 0; i < words.length; i++) {
                    words[i].classList.remove("activetext");
                }
                words[wordCounter].classList.add("activetext");
                wordCounter++;
            }
        }
        displayWord();
    </script>
     <script type="text/javascript">
        (function($) {
            "use strict";
            $(".event-news").owlCarousel({
