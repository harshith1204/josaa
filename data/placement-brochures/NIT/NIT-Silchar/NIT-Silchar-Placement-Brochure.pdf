            jQuery('iframe[src*="youtube.com"]').each(function() {
                jQuery(this).attr('referrerpolicy', 'strict-origin-when-cross-origin');
                // Reload the iframe to apply the new policy
                var src = jQuery(this).attr('src');
                jQuery(this).attr('src', src);
            });
        });
