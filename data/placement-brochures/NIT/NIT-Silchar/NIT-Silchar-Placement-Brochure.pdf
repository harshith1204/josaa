                filter: selector,
            });
            return false;
        });
        $(document).ready(function() {
            var popup_btn = $(".popup-btn");
            popup_btn.magnificPopup({
                type: "image",
                gallery: {
                    enabled: true,
                },
            });
            $(".gym-slider").owlCarousel({
                loop: true,
                margin: 15,
                nav: false,
                dots: true,
                autoplay: true,
                autoplayTimeout: 3000,
                autoplayHoverPause: true,
