'use client';

import { useState, useCallback } from 'react';
import { useRouter } from 'next/navigation';
import StoriesRow from '@/components/StoriesRow';
import StoryViewer from '@/components/StoryViewer';
import { storyColleges } from '@/data/colleges';

const features = [
  {
    icon: (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={1.5} className="w-6 h-6">
        <path d="M12 20V10M18 20V4M6 20v-4" strokeLinecap="round" strokeLinejoin="round" />
      </svg>
    ),
    title: 'AI Cutoff Analysis',
    description: 'Predict your admission chances with AI-powered cutoff analysis based on JoSAA 2025 data.',
    color: 'text-purple-400 bg-purple-500/10',
    href: '/cutoffs',
  },
  {
    icon: (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={1.5} className="w-6 h-6">
        <rect x="3" y="3" width="7" height="7" rx="1" />
        <rect x="14" y="3" width="7" height="7" rx="1" />
        <rect x="3" y="14" width="7" height="7" rx="1" />
        <rect x="14" y="14" width="7" height="7" rx="1" />
      </svg>
    ),
    title: '50 Preference Combos',
    description: 'Ready-made preference lists with different strategies - aggressive, safe, regional, branch-focused.',
    color: 'text-blue-400 bg-blue-500/10',
    href: '/cutoffs',
  },
  {
    icon: (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={1.5} className="w-6 h-6">
        <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" strokeLinecap="round" strokeLinejoin="round" />
        <circle cx="9" cy="7" r="4" />
        <path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" strokeLinecap="round" strokeLinejoin="round" />
      </svg>
    ),
    title: 'College Comparison',
    description: 'Compare NITs, IIITs and other institutes side by side - placements, NIRF, cutoffs.',
    color: 'text-green-400 bg-green-500/10',
    href: '/explore',
  },
  {
    icon: (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={1.5} className="w-6 h-6">
        <circle cx="12" cy="12" r="10" />
        <path d="M12 6v6l4 2" strokeLinecap="round" strokeLinejoin="round" />
      </svg>
    ),
    title: 'Engineering Counselling Simulator',
    description: 'Practice choice filling for JoSAA, NEET & EAMCET counselling with real cutoff data.',
    color: 'text-orange-400 bg-orange-500/10',
    href: '/simulator',
  },
  {
    icon: (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={1.5} className="w-6 h-6">
        <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" strokeLinecap="round" strokeLinejoin="round" />
      </svg>
    ),
    title: 'Placement Data',
    description: 'Access real placement statistics - median CTC, highest CTC, and top recruiters.',
    color: 'text-pink-400 bg-pink-500/10',
    href: '/explore',
  },
  {
    icon: (
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={1.5} className="w-6 h-6">
        <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" strokeLinecap="round" strokeLinejoin="round" />
      </svg>
    ),
    title: 'Branch Predictor',
    description: 'Enter your rank and get the best branch you can get at each NIT and IIIT.',
    color: 'text-cyan-400 bg-cyan-500/10',
    href: '/cutoffs',
  },
];

const searchHints = ['NIT Trichy CSE', 'Rank 5000 preference', 'All NITs ECE'];

const marqueeColleges = [
  'IIT-B', 'IIT-D', 'IIT-M', 'IIT-K', 'IIT-Kgp', 'NIT-T', 'NIT-K', 'NIT-R', 'NIT-W', 'NIT-C',
  'VNIT', 'MNIT', 'NIT-S', 'SVNIT', 'MNNIT', 'IIIT-A', 'IIITM-G', 'IIIT-H', 'NIT-D', 'NIT-J',
  'NIT-Kuk', 'NIT-Rpr', 'NIT-Goa', 'NIT-Ham', 'IIEST', 'PEC', 'BIT-M', 'IIIT-P', 'IIIT-B', 'IIIT-L',
];

export default function HomePage() {
  const router = useRouter();
  const [searchQuery, setSearchQuery] = useState('');
  const [storyOpen, setStoryOpen] = useState(false);
  const [storyIndex, setStoryIndex] = useState(0);

  // Search state
  const [isLoading, setIsLoading] = useState(false);
  const [searchResult, setSearchResult] = useState(null);
  const [searchError, setSearchError] = useState(null);

  const handleSearch = useCallback(async (e) => {
    e.preventDefault();
    const q = searchQuery.trim();
    if (!q) return;

    setIsLoading(true);
    setSearchResult(null);
    setSearchError(null);

    try {
      const res = await fetch('/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: q }),
      });

      if (!res.ok) throw new Error('Failed to get response');

      const data = await res.json();

      if (data.type === 'preference') {
        setSearchResult({
          type: 'preference',
          message: `Enter your rank (${data.userRank.toLocaleString()}) on the Cutoffs page to see personalized preference combos.`,
        });
      } else if (data.html) {
        setSearchResult({ type: 'html', content: data.answer });
      } else if (data.answer) {
        setSearchResult({ type: 'text', content: data.answer });
      } else {
        setSearchResult({ type: 'text', content: 'No results found. Try a different query.' });
      }
    } catch {
      setSearchError('Something went wrong. Please try again.');
    } finally {
      setIsLoading(false);
    }
  }, [searchQuery]);

  const dismissResult = () => {
    setSearchResult(null);
    setSearchError(null);
  };

  return (
    <div className="min-h-screen pb-20">
      {/* Hero Section */}
      <section className="px-4 pt-12 pb-8 text-center">
        {/* Badge */}
        <div className="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-purple-500/10 border border-purple-500/20 mb-6">
          <span className="w-2 h-2 rounded-full bg-green-400 animate-pulse" />
          <span className="text-xs text-purple-300 font-medium">Built on JoSAA 2025 Data</span>
        </div>

        {/* Heading with rotating words */}
        <h1 className="text-3xl sm:text-4xl md:text-5xl font-bold text-white leading-tight mb-2" style={{ fontFamily: 'Instrument Serif, serif' }}>
          Find your perfect
        </h1>
        <div className="h-12 sm:h-14 md:h-16 overflow-hidden mb-4">
          <div className="animate-rotate-words">
            {['college choice', 'preference list', 'admission odds', 'career path'].map((word) => (
              <div key={word} className="h-12 sm:h-14 md:h-16 flex items-center justify-center">
                <span className="text-3xl sm:text-4xl md:text-5xl font-bold bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent" style={{ fontFamily: 'Instrument Serif, serif' }}>
                  {word}
                </span>
              </div>
            ))}
          </div>
        </div>

        <p className="text-text-secondary text-sm sm:text-base max-w-md mx-auto">
          Answer 2 questions. Get instant AI recommendations.
        </p>
      </section>

      {/* Stories Row */}
      <section className="px-4 pb-6">
        <StoriesRow
          stories={storyColleges}
          onStoryClick={(index) => {
            setStoryIndex(index);
            setStoryOpen(true);
          }}
        />
        <StoryViewer
          isOpen={storyOpen}
          stories={storyColleges}
          initialIndex={storyIndex}
          onClose={() => setStoryOpen(false)}
        />
      </section>

      {/* Search Box */}
      <section className="px-4 pb-8">
        <form onSubmit={handleSearch} className="max-w-xl mx-auto">
          <div className="relative">
            <div className="absolute inset-y-0 left-4 flex items-center pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2} strokeLinecap="round" strokeLinejoin="round" className="w-5 h-5 text-gray-500">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
            </div>
            <input
              type="text"
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              placeholder="Ask: NIT Trichy CSE cutoff for rank 5000..."
              className="w-full bg-[#13131a] border border-white/10 rounded-2xl py-4 pl-12 pr-14 text-base text-white placeholder-gray-500 outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500/50 transition-all"
            />
            <button
              type="submit"
              disabled={isLoading}
              className="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-xl bg-purple-600 hover:bg-purple-500 disabled:opacity-50 transition-colors text-white"
            >
              {isLoading ? (
                <svg className="w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="3" className="opacity-25" />
                  <path d="M4 12a8 8 0 018-8" stroke="currentColor" strokeWidth="3" strokeLinecap="round" className="opacity-75" />
                </svg>
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2} className="w-5 h-5">
                  <line x1="22" y1="2" x2="11" y2="13" />
                  <polygon points="22 2 15 22 11 13 2 9 22 2" />
                </svg>
              )}
            </button>
          </div>

          {/* Search hint pills */}
          <div className="flex flex-wrap gap-2 mt-3 justify-center">
            {searchHints.map((hint) => (
              <button
                key={hint}
                type="button"
                onClick={() => setSearchQuery(hint)}
                className="px-3 py-1.5 rounded-full bg-[#1a1a2e] border border-white/10 text-xs text-gray-400 hover:text-purple-300 hover:border-purple-500/30 transition-all min-h-[36px]"
              >
                {hint}
              </button>
            ))}
          </div>
        </form>

        {/* Loading state */}
        {isLoading && (
          <div className="max-w-xl mx-auto mt-4 flex items-center justify-center gap-2 py-6">
            <svg className="w-5 h-5 animate-spin text-purple-400" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="3" className="opacity-25" />
              <path d="M4 12a8 8 0 018-8" stroke="currentColor" strokeWidth="3" strokeLinecap="round" className="opacity-75" />
            </svg>
            <span className="text-purple-300 text-sm">Thinking...</span>
          </div>
        )}

        {/* Search results */}
        {searchResult && !isLoading && (
          <div className="max-w-xl mx-auto mt-4 bg-[#13131a] border border-white/10 rounded-2xl overflow-hidden">
            <div className="p-4">
              {searchResult.type === 'preference' && (
                <div className="flex items-start gap-3">
                  <span className="text-2xl shrink-0">&#128203;</span>
                  <div>
                    <p className="text-gray-300 text-sm">{searchResult.message}</p>
                    <button
                      onClick={() => router.push('/cutoffs')}
                      className="mt-3 px-4 py-2 rounded-lg bg-purple-600 hover:bg-purple-500 text-white text-sm font-medium transition-colors min-h-[44px]"
                    >
                      Go to Cutoffs page
                    </button>
                  </div>
                </div>
              )}
              {searchResult.type === 'html' && (
                <div
                  className="text-gray-300 text-sm overflow-x-auto [&_table]:w-full [&_th]:text-left [&_th]:px-2 [&_th]:py-1.5 [&_th]:text-purple-400 [&_th]:text-xs [&_td]:px-2 [&_td]:py-1.5 [&_td]:text-xs [&_td]:border-t [&_td]:border-white/5 [&_tr:hover]:bg-white/5"
                  dangerouslySetInnerHTML={{ __html: searchResult.content }}
                />
              )}
              {searchResult.type === 'text' && (
                <p className="text-gray-300 text-sm">{searchResult.content}</p>
              )}
            </div>
            <div className="border-t border-white/10 px-4 py-3 flex justify-end">
              <button
                onClick={dismissResult}
                className="px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white text-sm transition-colors min-h-[44px]"
              >
                Close
              </button>
            </div>
          </div>
        )}

        {/* Error state */}
        {searchError && !isLoading && (
          <div className="max-w-xl mx-auto mt-4 bg-red-500/10 border border-red-500/20 rounded-2xl p-4">
            <div className="flex items-center gap-2">
              <span className="text-red-400">&#9888;</span>
              <p className="text-red-300 text-sm">{searchError}</p>
            </div>
            <button
              onClick={dismissResult}
              className="mt-3 px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white text-sm transition-colors min-h-[44px]"
            >
              Dismiss
            </button>
          </div>
        )}
      </section>

      {/* Features Grid */}
      <section className="px-4 pb-10">
        <h2 className="text-lg font-semibold text-white mb-4 text-center">Everything you need</h2>
        <div className="grid grid-cols-2 md:grid-cols-3 gap-3 max-w-3xl mx-auto">
          {features.map((feature, i) => (
            <button
              key={i}
              onClick={() => router.push(feature.href)}
              className="bg-[#13131a] border border-white/5 rounded-xl p-4 hover:border-purple-500/20 transition-all group cursor-pointer text-left min-h-[44px]"
            >
              <div className={`w-10 h-10 rounded-lg ${feature.color} flex items-center justify-center mb-3 group-hover:scale-110 transition-transform`}>
                {feature.icon}
              </div>
              <h3 className="text-white text-sm font-semibold mb-1">{feature.title}</h3>
              <p className="text-gray-500 text-xs leading-relaxed">{feature.description}</p>
            </button>
          ))}
        </div>
      </section>

      {/* Chat Demo Section */}
      <section className="px-4 pb-10">
        <div className="max-w-xl mx-auto bg-[#13131a] border border-white/5 rounded-2xl p-5">
          <div className="flex items-center gap-2 mb-4">
            <div className="w-6 h-6 rounded-full bg-gradient-to-br from-purple-500 to-pink-500" />
            <span className="text-xs text-gray-400 font-medium">cutoffs.ai</span>
          </div>

          {/* User message */}
          <div className="flex justify-end mb-3">
            <div className="bg-purple-600/20 border border-purple-500/20 rounded-2xl rounded-br-md px-4 py-2.5 max-w-[80%]">
              <p className="text-sm text-purple-200">What&apos;s the NIT Trichy CSE cutoff for rank 5000?</p>
            </div>
          </div>

          {/* AI response */}
          <div className="flex justify-start">
            <div className="bg-[#1e1e28] border border-white/5 rounded-2xl rounded-bl-md px-4 py-3 max-w-[85%]">
              <p className="text-sm text-gray-300 leading-relaxed">
                NIT Tiruchirappalli CSE (4Y, B.Tech) closing rank for General category in JoSAA 2025 was <span className="text-green-400 font-semibold">654</span>. With rank 5000, this is an aspirational choice. Consider NIT Calicut CSE (cutoff: 6,228) as a realistic target.
              </p>
              <div className="flex flex-wrap gap-2 mt-3">
                <span className="text-[10px] px-2 py-0.5 rounded-full bg-blue-500/20 text-blue-400 border border-blue-500/30">NIRF #9</span>
                <span className="text-[10px] px-2 py-0.5 rounded-full bg-purple-500/20 text-purple-400 border border-purple-500/30">NIT-1</span>
                <span className="text-[10px] px-2 py-0.5 rounded-full bg-green-500/20 text-green-400 border border-green-500/30">Est. 1964</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* College Marquee */}
      <section className="pb-8 overflow-hidden">
        <div className="relative">
          <div className="flex whitespace-nowrap animate-marquee">
            {[...marqueeColleges, ...marqueeColleges].map((college, i) => (
              <span
                key={i}
                className="inline-flex items-center px-4 py-2 mx-1.5 rounded-full bg-[#13131a] border border-white/5 text-xs text-gray-400 font-medium shrink-0"
              >
                {college}
              </span>
            ))}
          </div>
        </div>
      </section>
    </div>
  );
}
