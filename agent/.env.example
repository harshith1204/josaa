# Cloudflare AI (inference only — no D1, Vectorize, or R2)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_AI_TOKEN=your_cf_ai_api_token_here   # Needs Workers AI:Read permission

# Supabase (auth + pgvector + relational tables)
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AWS S3 (media file storage)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# Shared secret — frontend uses this to authenticate /ingest calls
INGEST_SECRET=change_me_to_a_random_secret

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://cutoffs.ai,http://localhost:3000
